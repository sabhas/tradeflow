# Copy to .env for docker compose: cp .env.docker.example .env

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=tradeflow
POSTGRES_PORT=5432

API_PORT=3001
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Set false after the first successful stack start to skip re-seeding on rebuild
RUN_SEED=true
