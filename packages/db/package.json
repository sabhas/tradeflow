{
  "name": "@tradeflow/db",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "migrate": "ts-node -r tsconfig-paths/register ./src/migrate.ts",
    "migrate:revert": "ts-node -r tsconfig-paths/register ./src/migrate-revert.ts",
    "migrate:generate": "typeorm migration:generate -d ./src/data-source.ts",
    "seed": "ts-node -r tsconfig-paths/register ./src/seed.ts"
  },
  "dependencies": {
    "@tradeflow/shared": "workspace:*",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.9.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3"
  }
}
