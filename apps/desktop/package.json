{
  "name": "desktop",
  "version": "1.0.0",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && tsc -p tsconfig.electron.json && cross-env ELECTRON_RUN_AS_NODE= electron .\"",
    "build": "tsc -p tsconfig.electron.json && vite build && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
